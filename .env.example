TELEGRAM_BOT_TOKEN=
APP_URL=https://your-domain.vercel.app

# MongoDB (required for deployed API/database)
MONGODB_URI=
MONGODB_DB=tliker

# Admin security
ADMIN_PASSWORD=
# Optional: restrict admin login to specific Telegram user IDs (comma separated)
ADMIN_USER_IDS=
# Optional extra secret for signing admin token (if empty, ADMIN_PASSWORD is used)
ADMIN_SECRET=
# Optional: allow admin login from browser (without Telegram user ID). true/false
ALLOW_WEB_ADMIN_LOGIN=true
